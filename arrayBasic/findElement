#Find an element in array

nums = int(input("Enter the number of element: "))
arr = []

for i  in range(1, nums+1):
    num = int(input("Enter the number:"))
    arr.append(num)

print("The original array is:", arr)

element = int(input("Enter the element you want to find: "))

if element in arr:
    print("The element", element, "is present in the array")
else:
    print("The element", element, "is not present in the array")
