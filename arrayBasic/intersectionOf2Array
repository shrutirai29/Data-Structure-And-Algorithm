#Print the intersection of 2 array

nums = int(input("Enter the number of elements in the arrays: "))
arr = []

print("Enter the first array:")
for i in range(1, nums+1):
    num = int(input("Enter the number: "))
    arr.append(num)

print("The original array is:", arr)

arr2 = []

print("Enter the second array:")
for i in range(1, nums+1):
    num = int(input("Enter the number: "))
    arr2.append(num)

print("The second array is:", arr2)

intersection = []

for i in arr:
    if i in arr2:
        intersection.append(i)

print("The intersection of the two arrays is:", intersection)
