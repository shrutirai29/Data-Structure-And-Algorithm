#sum of all odd numbers
#sum of all even numbers

end = int(input("Enter the end number: "))

sumOfEven = 0
sumOfOdd = 0

for i in range(1, end + 1):
    if i % 2 == 0:
        sumOfEven += i
    else:
        sumOfOdd += i

print("The sum of even numbers from 1 to", end, "is:", sumOfEven)
print("The sum of odd numbers from 1 to", end, "is:", sumOfOdd)
