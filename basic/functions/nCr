def fact(n: int) -> int:
    product = 1
    for i in range(1, n + 1):
        product *= i
    return product

def nCr(n: int, r: int) -> int:
    return fact(n) // (fact(r) * fact(n - r))

n = int(input("Enter the value of n: "))
r = int(input("Enter the value of r: "))

print("The value of nCr is:", nCr(n, r))
