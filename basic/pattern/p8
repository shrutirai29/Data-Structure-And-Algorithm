# 1 1 1 1
#  2 2 2
#    3 3
#      4

height = int(input("Enter the height: "))

for i in range(1, height + 1):
    print("  " * (i - 1), end="")

    for j in range(height - i + 1):
        print(i, end="")
        if j != height - i:  # don't print space after last number
            print(" ", end="")

    print()
